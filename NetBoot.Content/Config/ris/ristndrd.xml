<?xml version="1.0" encoding="utf-8" ?>
<Netboot>
	<sif type="Unattended">
		<content>
			<data>
				<floppyless>1</floppyless>
				<msdosinitiated>1</msdosinitiated>
				<AutoPartition>0</AutoPartition>
				<OriSrc>\\%SERVERNAME%\RemInst\%INSTALLPATH%\%MACHINETYPE%\</OriSrc>
				<OriTyp>4</OriTyp>
				<LocalSourceOnCD>1</LocalSourceOnCD>
				<DisableAdminAccountOnDomainJoin>no</DisableAdminAccountOnDomainJoin>
				<UnattendedInstall>yes</UnattendedInstall>
			</data>
			<SetupData>
				<OsLoadOptions>/fastdetect /noguiboot</OsLoadOptions>
				<SetupSourceDevice>"\Device\LanmanRedirector\%SERVERNAME%\RemInst\%INSTALLPATH%"</SetupSourceDevice>
			</SetupData>
			<Unattended>
				<OemPreInstall>yes</OemPreInstall>
				<UnattendMode>FullUnattended</UnattendMode>
				<NoWaitAfterTextMode>1</NoWaitAfterTextMode>
				<FileSystem>LeaveAlone</FileSystem>
				<ExtendOEMPartition>no</ExtendOEMPartition>
				<ConfirmHardware>yes</ConfirmHardware>
				<NtUpgrade>no</NtUpgrade>
				<Win31Upgrade>no</Win31Upgrade>
				<TargetPath>*</TargetPath>
				<OverwriteOemFilesOnUpgrade>no</OverwriteOemFilesOnUpgrade>
				<OemSkipEula>yes</OemSkipEula>
				<AutoActivate>no</AutoActivate>
				<InstallFilesPath>\\%SERVERNAME%\RemInst\%INSTALLPATH%\%MACHINETYPE%"</InstallFilesPath>
			</Unattended>
			<OEM_ADs>
				<Banner>Banner.bmp</Banner>
				<Logo>Logo.bmp</Logo>
				<Background>Background.bmp</Background>
			</OEM_ADs>
			<UserData>
				<FullName>Windows User</FullName>
				<OrgName>Private</OrgName>
				<ComputerName>[[#ComputerName#]]</ComputerName>
			</UserData>
			<GuiUnattended>
				<OemSkipWelcome>1</OemSkipWelcome>
				<OemSkipRegional>1</OemSkipRegional>
				<TimeZone>110</TimeZone>
				<AdminPassword>*</AdminPassword>
				<EncryptedAdminPassword>no</EncryptedAdminPassword>
			</GuiUnattended>
			<LicenseFilePrintData>
				<AutoMode>perSeat</AutoMode>
			</LicenseFilePrintData>
			<Display>
				<ConfigureAtLogon>1</ConfigureAtLogon>
				<BitsPerPel>32</BitsPerPel>
				<XResolution>1024</XResolution>
				<YResolution>768</YResolution>
				<VRefresh>60</VRefresh>
				<AutoConfirm>1</AutoConfirm>
			</Display>
			<Network>
				<ProcessPageSections>1</ProcessPageSections>
			</Network>
			<Identification>
				<JoinDomain>FBLIPKE</JoinDomain>
				<CreateComputerAccountInDomain>yes</CreateComputerAccountInDomain>
				<DoOldStyleDomainJoin>yes</DoOldStyleDomainJoin>
			</Identification>
			<RemoteInstall>
				<Repartition>No</Repartition>
				<UseWholeDisk>No</UseWholeDisk>
			</RemoteInstall>
			<OSChooser>
				<Description>[[#Description#]]</Description>
				<Help>[[#Help#]]</Help>
				<LaunchFile>[[#LaunchFile#]]</LaunchFile>
				<ImageType>[[#ImageType#]]</ImageType>
				<Version>[[#Version#]]</Version>
			</OSChooser>
		</content>
	</sif>
</Netboot>